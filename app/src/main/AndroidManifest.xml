<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        PRIVACY CONSTRAINT: this app declares NO permissions at all. Without
        android.permission.INTERNET the process cannot open a socket, which makes
        exfiltration of key material impossible regardless of included libraries.
        The :app build has a verifyNoNetwork* task that fails the build if any
        network permission ever reaches the merged manifest.

        CAMERA is used only to scan shard QR codes during recovery; it is
        runtime-requested and never required to install or to use the
        type-words / import-file recovery paths.
    -->

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShardQuorum"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ShardQuorum">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Exposes a single staged shard PNG from cache/shared so it can be
            handed to a share target. exported=false + per-Intent read grant
            means only the chosen app, for that one share, can read it.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
